{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": ["ultracite/core"],
  "files": {
    "includes": ["**/*.{js,jsx,ts,tsx,json,jsonc,css}", "!src/**/*.astro"]
  },
  "linter": {
    "rules": {
      "suspicious": {
        "noUnknownAtRules": {
          "level": "off"
        }
      }
    }
  }
}
