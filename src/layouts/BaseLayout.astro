---
import Footer from "@/src/components/Footer.astro";
import Header from "@/src/components/Header.astro";
import OSSActivity from "@/src/components/OSSActivity.astro";
import Profile from "@/src/components/Profile.astro";
import { type Appearance, personConfig } from "@/lib/site-config";
import { ClientRouter } from "astro:transitions";
import "@/src/styles/globals.css";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = `${personConfig.name} — Founding Engineer at Inth, co-author of c15t`,
  description = personConfig.description,
} = Astro.props;
const ogImageUrl = new URL("/opengraph-image", personConfig.siteUrl).toString();
const canonicalUrl = new URL(
  Astro.url.pathname,
  personConfig.siteUrl
).toString();
const trimmedPath = Astro.url.pathname.replace(/\/+$/, "");
const markdownPath = trimmedPath === "" ? "/index.md" : `${trimmedPath}.md`;
const githubUrl = personConfig.sameAs.find((url) =>
  url.includes("github.com/")
);
const githubUsername = githubUrl?.split("/").at(-1) ?? "";

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=3600, stale-while-revalidate=86400"
);

const appearances = (personConfig.appearances ?? []) as Appearance[];
const talks = appearances.filter((appearance) => appearance.type === "talk");

// Breadcrumb trail (Home > segment > …) for the BreadcrumbList node.
const siteRoot = personConfig.siteUrl.replace(/\/$/, "");
const crumbs = [{ name: "Home", item: `${siteRoot}/` }];
let crumbPath = siteRoot;
for (const segment of Astro.url.pathname.split("/").filter(Boolean)) {
  crumbPath += `/${segment}`;
  crumbs.push({
    name: segment.charAt(0).toUpperCase() + segment.slice(1),
    item: crumbPath,
  });
}

const personId = `${siteRoot}/#person`;
const websiteId = `${siteRoot}/#website`;

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": personId,
      name: personConfig.name,
      url: personConfig.siteUrl,
      jobTitle: personConfig.jobTitle,
      worksFor: {
        "@type": "Organization",
        name: "Inth",
        url: "https://inth.com",
      },
      sameAs: personConfig.sameAs,
      ...(talks.length > 0
        ? {
            performerIn: talks.map((talk) => ({
              "@type": "Event",
              name: talk.title,
              ...(talk.url ? { url: talk.url } : {}),
              ...(talk.date ? { startDate: talk.date } : {}),
              superEvent: {
                "@type": "Event",
                name: talk.event,
                ...(talk.eventUrl ? { url: talk.eventUrl } : {}),
              },
            })),
          }
        : {}),
    },
    {
      "@type": "WebSite",
      "@id": websiteId,
      url: personConfig.siteUrl,
      name: personConfig.name,
      description: personConfig.description,
      publisher: { "@id": personId },
    },
    {
      "@type": "WebPage",
      "@id": canonicalUrl,
      url: canonicalUrl,
      name: title,
      description,
      isPartOf: { "@id": websiteId },
      about: { "@id": personId },
      dateModified: new Date().toISOString(),
      breadcrumb: { "@id": `${canonicalUrl}#breadcrumb` },
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonicalUrl}#breadcrumb`,
      itemListElement: crumbs.map((crumb, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: crumb.name,
        item: crumb.item,
      })),
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content={`${personConfig.name}, software engineer, full-stack developer, open source, c15t, TypeScript, React`}
    />
    <meta name="author" content={personConfig.name} />
    <link rel="canonical" href={canonicalUrl} />
    <link
      rel="alternate"
      type="text/markdown"
      href={markdownPath}
      title="This page (Markdown)"
    />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={personConfig.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:creator" content={personConfig.twitterHandle} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="icon" href="/favicon.ico" />
    <script
      is:inline
      set:html={`(()=>{const apply=()=>{try{const t=localStorage.getItem("theme");const d=t==="dark"||(!t&&matchMedia("(prefers-color-scheme: dark)").matches);document.documentElement.classList.toggle("dark",d)}catch{}};apply();if(!window.__themeApplyBound){window.__themeApplyBound=true;document.addEventListener("astro:after-swap",apply)}})()`}
    />
    <script
      is:inline
      set:html={`console.log("%cconsole.log(\\"here?\\") — yep, you found it 👀","color:#8b5cf6;font-weight:700;font-size:13px");console.log("%cHi, I'm Kaylee. I build c15t → https://c15t.com","color:#a78bfa");`}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />
    <ClientRouter />
  </head>
  <body class="grid-background antialiased">
    <div class="min-h-screen">
      <div class="container mx-auto max-w-(--breakpoint-lg) px-4 py-8">
        <div class="grid grid-cols-1 gap-6 md:grid-cols-3 md:gap-x-10">
          <aside
            class="md:col-span-1 md:sticky md:top-8 md:self-start md:space-y-6"
            transition:persist="sidebar"
          >
            <Profile />
            {githubUsername ? <OSSActivity username={githubUsername} /> : null}
          </aside>
          <main class="space-y-6 md:col-span-2">
            <Header />
            <slot />
          </main>
        </div>
      </div>
    </div>
    <Footer />
  </body>
</html>
