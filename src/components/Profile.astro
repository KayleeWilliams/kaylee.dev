---
import { getSiteContent } from "@/lib/get-site-content";
import { renderMarkdown } from "@/lib/render-markdown";
import { personConfig, socialConfig } from "@/lib/site-config";
import Card from "./Card.astro";
import CardContent from "./CardContent.astro";
import FlipPhoto from "./FlipPhoto.astro";
import Icon from "./Icon.astro";

const profile = await getSiteContent("profile");

const iconByName = {
  Github: "github",
  LinkedIn: "linkedin",
  Twitter: "twitter",
} as const;
---

{
  profile ? (
    <Card class="h-fit">
      <CardContent class="pt-6">
        <div class="flex flex-col items-start gap-2">
          <div class="flex w-full flex-row items-center gap-4 md:flex-col md:items-start">
            <FlipPhoto
              class="rounded-full md:mx-auto"
            />
            <div class="flex flex-col items-start justify-center">
              <h1 class="font-bold text-xl md:mt-4 md:text-2xl">
                {personConfig.name}
              </h1>
              <p class="text-foreground text-sm md:text-base">
                {personConfig.headline}
              </p>
            </div>
          </div>
          <div
            class="markdown-content mt-2 text-start text-foreground text-sm"
            set:html={renderMarkdown(profile.content)}
          />

          <div class="flex w-full flex-col space-y-2 border-border border-t pt-4">
            {socialConfig.map((social) => {
              const parts = social.url.split("/");
              const username = parts.at(-1);
              const icon =
                iconByName[social.name as keyof typeof iconByName] ??
                "external-link";

              return (
                <a
                  aria-label={`${social.name} Logo`}
                  class="group flex cursor-pointer items-center gap-2"
                  href={social.url}
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  <Icon class="size-4 text-violet-400" name={icon} />
                  <p class="text-foreground text-sm transition-color duration-200 ease-linear group-hover:text-primary">
                    {username}
                  </p>
                </a>
              );
            })}
          </div>
        </div>
      </CardContent>
    </Card>
  ) : null
}
