---
import { getImage } from "astro:assets";
import kayleeImage from "@/src/assets/kaylee.jpg";
import Pill from "@/src/components/Pill.astro";
import { personConfig } from "@/lib/site-config";
import { withUtm } from "@/lib/utils/utm";

// Shared profile header for the /connect surfaces so the linktree page and the
// QR share view can never drift apart.
type Props = {
  class?: string;
};

const { class: className = "" } = Astro.props;

const avatar = await getImage({
  src: kayleeImage,
  width: 240,
  height: 240,
  format: "webp",
  quality: 82,
});
---

<header
  class:list={[
    "relative flex items-center gap-4 rounded-lg border border-border bg-card p-5 shadow-xs",
    className,
  ]}
>
  <Pill class="-top-2.5 -right-2 rotate-[8deg]">SAY HI</Pill>
  <img
    alt="Kaylee Williams"
    class="size-20 shrink-0 rounded-full border-2 border-gray-200 object-cover object-top shadow-sm"
    decoding="async"
    fetchpriority="high"
    height="240"
    src={avatar.src}
    width="240"
  />
  <div class="min-w-0">
    <h1 class="font-bold text-2xl leading-tight tracking-tight">
      {personConfig.name}
    </h1>
    <p class="mt-1.5 text-pretty text-foreground/75 text-sm leading-snug">
      Founding engineer at Inth (YC P26) and co-author of
      <a
        class="font-semibold text-primary underline-offset-2 hover:underline"
        href={withUtm(personConfig.primaryProjectUrl, "connect-profile", "c15t")}
        rel="noopener noreferrer"
        target="_blank">c15t</a
      >.
    </p>
  </div>
</header>
