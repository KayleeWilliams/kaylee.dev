---
import { personConfig } from "@/lib/site-config";
import { withUtm } from "@/lib/utils/utm";
import Icon from "./Icon.astro";

const currentYear = new Date().getFullYear();
---

<footer class="container mx-auto max-w-(--breakpoint-lg) px-4 pb-8">
  <div
    class="flex flex-col items-center gap-2 border-border border-t pt-6 text-center text-muted-foreground text-sm"
  >
    <p>
      No cookie banner needed - this site uses privacy-first analytics.
      <br class="hidden sm:block" />
      <span class="text-foreground">
        But if it did, it'd use{" "}
        <a
          class="font-medium text-primary hover:underline"
          href={withUtm(personConfig.primaryProjectUrl, "footer", "c15t")}
          rel="noopener noreferrer"
          target="_blank"
        >
          c15t
        </a>.
      </span>
    </p>
    <div class="flex items-center gap-3 text-muted-foreground/60">
      <a
        class="flex items-center gap-1 transition-colors duration-150 hover:text-foreground"
        href={withUtm(personConfig.sourceRepo, "footer", "view-source")}
        rel="noopener noreferrer"
        target="_blank"
      >
        <Icon class="size-4" name="github" />
        <span>View Source</span>
      </a>
      <a
        aria-label="Dig through my record crate"
        class="vinyl-wink transition-colors duration-150 hover:text-primary"
        href="/records"
      >
        <svg class="vinyl size-3.5" fill="none" viewBox="0 0 24 24">
          <circle cx="12" cy="12" r="9.2" stroke="currentColor" stroke-width="1.4" />
          <circle
            cx="12"
            cy="12"
            opacity="0.55"
            r="5.4"
            stroke="currentColor"
            stroke-width="0.9"
          />
          <circle cx="12" cy="12" fill="currentColor" r="2.1" />
        </svg>
      </a>
      <p>© {currentYear} {personConfig.name}</p>
    </div>
  </div>
</footer>

<style>
  /* Earned whimsy: the record only spins for whoever bothers to hover it. */
  .vinyl {
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .vinyl-wink:hover .vinyl {
    animation: vinyl-wink-spin 4.5s linear infinite;
  }
  @keyframes vinyl-wink-spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>
