---
import { getGitHubContributionCalendar } from "@/lib/get-github-contribution-calendar";
import Card from "./Card.astro";
import CardContent from "./CardContent.astro";
import CardHeader from "./CardHeader.astro";
import CardTitle from "./CardTitle.astro";

type Props = {
  username: string;
};

const { username } = Astro.props;
const calendar = await getGitHubContributionCalendar(username);

const levelClasses = {
  0: "bg-[oklch(0.97_0.015_300)] ring-[oklch(0.91_0.025_300)] dark:bg-[oklch(0.28_0.018_260)] dark:ring-[oklch(0.39_0.026_260)]",
  1: "bg-[oklch(0.88_0.055_300)] ring-[oklch(0.82_0.07_300)] dark:bg-[oklch(0.34_0.055_285)] dark:ring-[oklch(0.42_0.065_285)]",
  2: "bg-[oklch(0.78_0.09_300)] ring-[oklch(0.72_0.11_300)] dark:bg-[oklch(0.43_0.085_285)] dark:ring-[oklch(0.51_0.095_285)]",
  3: "bg-[oklch(0.67_0.145_300)] ring-[oklch(0.62_0.16_300)] dark:bg-[oklch(0.53_0.13_285)] dark:ring-[oklch(0.61_0.13_285)]",
  4: "bg-[oklch(0.56_0.19_300)] ring-[oklch(0.52_0.19_300)] dark:bg-[oklch(0.66_0.13_285)] dark:ring-[oklch(0.72_0.12_285)]",
} as const;

function formatDay(date: string): string {
  return new Date(`${date}T00:00:00Z`).toLocaleDateString("en", {
    day: "numeric",
    month: "short",
    timeZone: "UTC",
  });
}
---

{
  calendar ? (
    <Card>
      <CardHeader class="pb-4">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <CardTitle as="h2" class="text-lg">GitHub contributions</CardTitle>
            <p class="mt-1 max-w-prose text-muted-foreground text-sm leading-snug">
              {calendar.total.toLocaleString()} public contributions in the last{" "}
              {calendar.rangeDays} days
            </p>
          </div>
          <p class="shrink-0 text-muted-foreground text-xs tabular-nums">
            {calendar.activeDays} active days
          </p>
        </div>
      </CardHeader>
      <CardContent>
        <div class="pb-1">
          <div
            aria-label={`${calendar.total.toLocaleString()} GitHub contributions across the last ${calendar.rangeDays} days`}
            class="grid grid-flow-col grid-rows-6 gap-[3px] [grid-auto-columns:minmax(0,1fr)] sm:gap-1"
            role="img"
          >
            {calendar.days.map((day) => (
              <time
                aria-label={`${day.count.toLocaleString()} ${
                  day.count === 1 ? "contribution" : "contributions"
                } on ${formatDay(day.date)}`}
                class={`aspect-square rounded-[2px] ring-1 ${levelClasses[day.level]}`}
                datetime={day.date}
                title={`${day.count.toLocaleString()} ${
                  day.count === 1 ? "contribution" : "contributions"
                } on ${formatDay(day.date)}`}
              />
            ))}
          </div>
          <div class="mt-3 flex items-center justify-end text-muted-foreground text-xs">
            <div class="flex items-center gap-1.5" aria-hidden="true">
              <span>Less</span>
              <span
                class={`size-2 rounded-[2px] ring-1 ${levelClasses[0]}`}
              />
              <span
                class={`size-2 rounded-[2px] ring-1 ${levelClasses[1]}`}
              />
              <span
                class={`size-2 rounded-[2px] ring-1 ${levelClasses[2]}`}
              />
              <span
                class={`size-2 rounded-[2px] ring-1 ${levelClasses[3]}`}
              />
              <span
                class={`size-2 rounded-[2px] ring-1 ${levelClasses[4]}`}
              />
              <span>More</span>
            </div>
          </div>
        </div>
      </CardContent>
    </Card>
  ) : null
}
