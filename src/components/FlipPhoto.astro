---
import { getImage } from "astro:assets";
import catImage from "@/src/assets/cat.jpeg";
import conferenceImage from "@/src/assets/conference.jpeg";
import Pill from "./Pill.astro";

type Props = {
  class?: string;
};

const { class: className = "" } = Astro.props;
const imageClass =
  "h-full w-full rounded-full border-2 border-gray-200 object-cover object-top shadow-md transition-colors duration-200 hover:border-violet-500";
const transparentPixel =
  "data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==";
const [conferenceMobile, conferenceDesktop, catDesktop] = await Promise.all([
  getImage({
    src: conferenceImage,
    width: 64,
    height: 64,
    format: "webp",
    quality: 82,
  }),
  getImage({
    src: conferenceImage,
    width: 240,
    height: 240,
    format: "webp",
    quality: 82,
  }),
  getImage({
    src: catImage,
    width: 240,
    height: 240,
    format: "webp",
    quality: 82,
  }),
]);
---

<div class={`relative ${className}`}>
  <div class="flip-card size-12 md:size-60">
    <div class="flip-card-inner flip-card-auto">
      <div class="flip-card-front">
        <picture>
          <source
            media="(min-width: 768px)"
            srcset={conferenceDesktop.src}
            type="image/webp"
          />
          <img
            alt="Speaking at Next.js Conf London"
            class={imageClass}
            decoding="async"
            fetchpriority="high"
            height="240"
            src={conferenceMobile.src}
            width="240"
          />
        </picture>
      </div>
      <div class="flip-card-back">
        <picture>
          <source
            media="(min-width: 768px)"
            srcset={catDesktop.src}
            type="image/webp"
          />
          <img
            alt="My cat Kibby"
            class={imageClass}
            decoding="async"
            height="240"
            loading="lazy"
            src={transparentPixel}
            width="240"
          />
        </picture>
      </div>
    </div>
  </div>

  <Pill class="top-5 left-[3.5px] hidden flip-pill -rotate-40 md:block">
    MY CAT 🐱
  </Pill>
</div>
