---
import { getAllProjects } from "@/lib/get-all-projects";
import { personConfig } from "@/lib/site-config";
import Card from "./Card.astro";
import Icon from "./Icon.astro";

type IconName = "star" | "github" | "mic";
type Stat = {
  icon: IconName;
  iconClass: string;
  label: string;
  value: string;
};

const projects = await getAllProjects({ includeStars: true });
const active = projects.filter((project) => project.active);

const totalStars = active.reduce(
  (sum, project) => sum + (project.stars ?? 0),
  0
);
const ossProjects = active.filter((project) => project.github).length;
const appearances = (personConfig.appearances ?? []).length;

// Aggregate signals only — c15t-specific stars/downloads live in the Hero card,
// so this strip stays complementary rather than duplicative.
const stats: Stat[] = [];
if (totalStars > 0) {
  stats.push({
    icon: "star",
    iconClass: "text-yellow-500",
    value: `${totalStars.toLocaleString()}+`,
    label: "GitHub stars",
  });
}
if (ossProjects > 0) {
  stats.push({
    icon: "github",
    iconClass: "text-foreground",
    value: `${ossProjects}`,
    label: ossProjects === 1 ? "OSS project" : "OSS projects",
  });
}
if (appearances > 0) {
  stats.push({
    icon: "mic",
    iconClass: "text-violet-400",
    value: `${appearances}`,
    label: "Talks & appearances",
  });
}

const colsClass =
  { 1: "grid-cols-1", 2: "grid-cols-2", 3: "grid-cols-3" }[stats.length] ??
  "grid-cols-3";
---

{
  stats.length > 1 ? (
    <Card>
      <ul class:list={["grid divide-x divide-border", colsClass]}>
        {stats.map((stat) => (
          <li class="flex flex-col items-center gap-1 px-4 py-5 text-center">
            <Icon class={`size-5 ${stat.iconClass}`} name={stat.icon} />
            <span class="font-bold text-2xl text-foreground tabular-nums tracking-tight">
              {stat.value}
            </span>
            <span class="text-muted-foreground text-xs">{stat.label}</span>
          </li>
        ))}
      </ul>
    </Card>
  ) : null
}
