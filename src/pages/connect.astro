---
import { getImage } from "astro:assets";
import c15tLogo from "@/src/assets/c15t.png";
import inthLogo from "@/src/assets/inth.png";
import ConnectProfile from "@/src/components/ConnectProfile.astro";
import Icon from "@/src/components/Icon.astro";
import BaseLayout from "@/src/layouts/BaseLayout.astro";
import { pageSeo } from "@/lib/seo";
import { personConfig, socialConfig } from "@/lib/site-config";
import { withUtm } from "@/lib/utils/utm";

export const prerender = true;

const [c15tIcon, inthIcon] = await Promise.all([
  getImage({
    src: c15tLogo,
    width: 96,
    height: 96,
    format: "webp",
    quality: 90,
  }),
  getImage({
    src: inthLogo,
    width: 96,
    height: 96,
    format: "webp",
    quality: 90,
  }),
]);

type IconName = "github" | "linkedin" | "x" | "bluesky";

// Icon-only row, so the brand glyph IS the label. Keyed by socials.json name.
const socialMeta: Record<string, { icon: IconName; label: string }> = {
  Github: { icon: "github", label: "GitHub" },
  LinkedIn: { icon: "linkedin", label: "LinkedIn" },
  Twitter: { icon: "x", label: "X" },
  Bluesky: { icon: "bluesky", label: "Bluesky" },
};

const socials = socialConfig
  .map((social) => {
    const meta = socialMeta[social.name];
    return meta ? { ...meta, url: social.url } : null;
  })
  .filter(
    (social): social is { icon: IconName; label: string; url: string } =>
      social !== null
  );

type Site = {
  label: string;
  sub: string;
  href: string;
  external: boolean;
  monogram?: string;
  img?: { src: string; alt: string };
};

const sites: Site[] = [
  {
    monogram: "K",
    label: "My Site",
    sub: "kaylee.dev",
    href: "/",
    external: false,
  },
  {
    img: { src: inthIcon.src, alt: "Inth logo" },
    label: "Inth",
    sub: "inth.com",
    href: withUtm("https://inth.com", "connect", "inth"),
    external: true,
  },
  {
    img: { src: c15tIcon.src, alt: "c15t logo" },
    label: "c15t",
    sub: "c15t.com",
    href: withUtm(personConfig.primaryProjectUrl, "connect", "c15t"),
    external: true,
  },
];
---

<BaseLayout
  title={pageSeo.connect.title}
  description={pageSeo.connect.description}
  variant="minimal"
>
  <div class="flex flex-col gap-6">
    <ConnectProfile class="rise" />

    <nav
      aria-label="Social profiles"
      class="rise grid grid-cols-4 gap-3"
      style="animation-delay:80ms"
    >
      {
        socials.map((social) => (
          <a
            aria-label={social.label}
            class="group flex aspect-square items-center justify-center rounded-lg border border-border bg-card text-foreground shadow-xs outline-none transition-[transform,border-color,background-color,color] duration-200 ease-out hover:-translate-y-0.5 hover:border-violet-300 hover:bg-violet-50 hover:text-primary focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background active:translate-y-0 dark:hover:border-violet-500/40 dark:hover:bg-violet-500/10"
            href={social.url}
            rel="noopener noreferrer"
            target="_blank"
          >
            <Icon class="size-7" name={social.icon} />
          </a>
        ))
      }
    </nav>

    <ul class="flex flex-col gap-3">
      {
        sites.map((site, index) => (
          <li
            class="rise"
            style={`animation-delay:${140 + index * 60}ms`}
          >
            <a
              class="group flex items-center gap-4 rounded-lg border border-border bg-card p-3.5 shadow-xs outline-none transition-[transform,border-color,box-shadow] duration-200 ease-out hover:-translate-y-0.5 hover:border-violet-300 hover:shadow-md focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background active:translate-y-0 dark:hover:border-violet-500/40"
              href={site.href}
              rel={site.external ? "noopener noreferrer" : undefined}
              target={site.external ? "_blank" : undefined}
            >
              {site.img ? (
                <img
                  alt={site.img.alt}
                  class="size-11 shrink-0 rounded-md object-cover shadow-xs"
                  height="44"
                  src={site.img.src}
                  width="44"
                />
              ) : (
                <span class="grid size-11 shrink-0 place-items-center rounded-md bg-violet-600 font-bold text-lg text-white shadow-xs">
                  {site.monogram}
                </span>
              )}
              <span class="min-w-0 flex-1">
                <span class="block font-semibold leading-tight">
                  {site.label}
                </span>
                <span class="block truncate text-muted-foreground text-sm">
                  {site.sub}
                </span>
              </span>
              <Icon
                class="size-4 shrink-0 text-muted-foreground transition-[color,transform] duration-200 ease-out group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-primary"
                name="arrow-up-right"
              />
            </a>
          </li>
        ))
      }
    </ul>

    <a
      class="rise group inline-flex items-center justify-center gap-2 self-center rounded-lg px-3 py-2 text-muted-foreground text-sm outline-none transition-colors duration-150 hover:text-primary focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 focus-visible:ring-offset-background"
      href="/connect/share"
      style="animation-delay:320ms"
    >
      <Icon class="size-4" name="qr" />
      <span class="font-medium">Share</span>
    </a>
  </div>
</BaseLayout>
